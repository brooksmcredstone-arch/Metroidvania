config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Metroidvania"
run/main_scene="uid://545uvo36q808"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://dukxccvsmgrmv"

[audio]

buses/default_bus_layout="uid://dn6krk0ee8n5h"

[autoload]

SceneManager="*res://metroidvania_project/00_global/scene_manager/scene_manager.tscn"
SaveManager="*res://metroidvania_project/00_global/save_manager.gd"
Messages="*res://metroidvania_project/00_global/messages.gd"
PlayerHud="*res://metroidvania_project/00_global/player_hud/player_hud.tscn"
Audio="*uid://bgssuupd2e77p"
VisualEffects="*uid://cyqh4ahisurs4"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=900
window/size/window_height_override=650
window/stretch/mode="canvas_items"

[global_group]

